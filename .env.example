# =========================================================================
# OMNIBITE MONOREPO PLATFORM CONFIGURATION EXAMPLE
# Copy this file to .env in each service directory (or root if using Docker/orchestrators)
# =========================================================================

# Port Configurations
GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
MENU_SERVICE_PORT=5002
ORDER_SERVICE_PORT=5003
INVENTORY_SERVICE_PORT=5004
LOYALTY_SERVICE_PORT=5005
NOTIFICATION_SERVICE_PORT=5006
FRONTEND_PORT=3000

# Security
JWT_SECRET=super-secret-key-restaurant-platform
JWT_EXPIRES_IN=24h

# Redis Caching & Event Bus Config
# Defaults to localhost. In-memory fallback will automatically trigger if Redis is offline
REDIS_URL=redis://localhost:6379

# Isolated MongoDB Databases Connection URIs
# Respects microservice boundaries by maintaining separate namespaces
AUTH_SERVICE_MONGO_URI=mongodb://localhost:27017/restaurant_platform_auth
MENU_SERVICE_MONGO_URI=mongodb://localhost:27017/restaurant_platform_menu
ORDER_SERVICE_MONGO_URI=mongodb://localhost:27017/restaurant_platform_orders
INVENTORY_SERVICE_MONGO_URI=mongodb://localhost:27017/restaurant_platform_inventory
LOYALTY_SERVICE_MONGO_URI=mongodb://localhost:27017/restaurant_platform_loyalty
NOTIFICATION_SERVICE_MONGO_URI=mongodb://localhost:27017/restaurant_platform_notifications
